{
  "crons": [
    {
      "path": "/api/cron/grace-period-checker",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/trial-end-checker",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/daily-tasks-digest",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:svg|png|jpg|jpeg|gif|webp|ico|woff|woff2))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
