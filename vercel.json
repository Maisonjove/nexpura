{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "regions": ["syd1"],
  "ignoreCommand": "bash scripts/should-build.sh",
  "functions": {
    "src/app/(app)/dashboard/page.tsx": {
      "maxDuration": 60
    },
    "src/app/(app)/layout.tsx": {
      "maxDuration": 60
    },
    "src/app/api/health/route.ts": {
      "maxDuration": 5
    },
    "src/app/api/warm/route.ts": {
      "maxDuration": 5
    },
    "src/app/(app)/pos/page.tsx": {
      "maxDuration": 30
    },
    "src/app/(app)/inventory/page.tsx": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/grace-period-checker",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/trial-end-checker",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/daily-tasks-digest",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/scheduled-reports",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/overdue-invoices",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/payment-required",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/backup-check",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/warm",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/dashboard/warm",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/migration-chunk-runner",
      "schedule": "* * * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:svg|png|jpg|jpeg|gif|webp|ico|woff|woff2))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
